# ==========================================
# VARIABLES DE ENTORNO PARA SISTEMA DRA. KELY
# ==========================================

# 1. Supabase (Base de datos y Autenticación)
NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key-publica"
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key-privada" # Necesario para saltar RLS y subir comprobantes

# 2. Telegram (Notificaciones PUSH para la doctora)
TELEGRAM_BOT_TOKEN="token-botfather"
TELEGRAM_CHAT_ID="id-del-chat-o-grupo"

# 3. YCloud (WhatsApp API)
YCLOUD_API_KEY="tu-ycloud-api-key"
YCLOUD_WEBHOOK_SECRET="tu-ycloud-webhook-secret"
YCLOUD_PHONE_NUMBER_ID="tu-phone-number-id"

# 4. Motor de IA — Solo necesitas UNO de los tres
# Proveedor activo: "anthropic" | "openai" | "gemini"
AI_PROVIDER="anthropic"

# Anthropic (Claude) — Proveedor por defecto
ANTHROPIC_API_KEY="tu-anthropic-api-key"
ANTHROPIC_MODEL="claude-haiku-4-5-20250315"

# OpenAI (GPT) — Alternativa
OPENAI_API_KEY="tu-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"

# Google Gemini — Alternativa
GEMINI_API_KEY="tu-gemini-api-key"
GEMINI_MODEL="gemini-2.0-flash"

# 5. Datos de la aplicación
NEXT_PUBLIC_APP_URL="http://localhost:3000" # Cambiar en producción (ej. https://kely-crm.vercel.app)

# 6. Cron Jobs
CRON_SECRET="kelly-cron-secret-2026"
